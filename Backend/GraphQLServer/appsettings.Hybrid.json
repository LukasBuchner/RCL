{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Extensions.Hosting": "Warning",
        "System": "Warning",
        "HotChocolate.Execution": "Information",
        "HotChocolate": "Information"
      }
    }
  },
  "Scene": {
    "ConfigurationFile": "Config/scene-config.json",
    "AutoLoad": true
  },
  "Skills": {
    "ConfigurationFile": "Config/skills-config.json",
    "AutoLoad": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174"
    ]
  },
  "Agents": {
    "DummyAgents": {
      "Enabled": true,
      "ConfigurationFile": "Config/dummy-agents-config.json",
      "AutoLoad": true
    },
    "KukaAgents": {
      "Enabled": true,
      "ConfigurationFile": "Config/kuka-agents-config.json",
      "AutoLoad": true
    }
  }
}
