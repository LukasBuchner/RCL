{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Extensions.Hosting": "Information",
        "System": "Warning",
        "FHOOE.Freydis.Scheduling": "Information",
        "FHOOE.Freydis.Application": "Information",
        "FHOOE.Freydis.Application.Services.Execution": "Information",
        "FHOOE.Freydis.Agents": "Information",
        "FHOOE.Freydis.GraphQLServer": "Information",
        "HotChocolate.Execution": "Warning",
        "HotChocolate": "Warning"
      }
    }
  },
  "Scene": {
    "ConfigurationFile": "Config/scene-config.json",
    "AutoLoad": true
  },
  "Skills": {
    "ConfigurationFile": "Config/skills-config.json",
    "AutoLoad": true
  },
  "Agents": {
    "DummyAgents": {
      "Enabled": true,
      "ConfigurationFile": "Config/dummy-agents-config.json",
      "AutoLoad": true
    }
  }
}
