{
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=FreydisDB;Username=postgres;Password=postgres;Maximum Pool Size=50;Minimum Pool Size=5;Connection Idle Lifetime=300"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {}
    }
  },
  "AllowedHosts": "*",
  "GraphQL": {
    "Cost": {
      "MaxFieldCost": 4000,
      "MaxTypeCost": 1000,
      "EnforceCostLimits": true,
      "ApplyCostDefaults": true,
      "DefaultResolverCost": 10.0
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174"
    ]
  },
  "Agents": {
    "DummyAgents": {
      "Enabled": true,
      "ConfigurationFile": "alice-bob-charlie-robot-config.json",
      "AutoLoad": true
    },
    "KukaAgents": {
      "Enabled": false,
      "ConfigurationFile": "Config/kuka-agents-config.json",
      "AutoLoad": false
    },
    "RealAgents": {
      "Enabled": false,
      "DiscoveryEndpoint": null,
      "AutoStart": false
    },
    "DigitalTwin": {
      "Enabled": true,
      "NominalDurationSeconds": 5.0,
      "PingIntervalSeconds": 10.0,
      "PongTimeoutSeconds": 30.0,
      "EstimateTimeoutSeconds": 2.0,
      "MaxConcurrentExecutions": 1,
      "ReceiveBufferSize": 4096
    }
  },
  "ExecutionPipeline": {
    "RescheduleSampleIntervalMs": 18.0,
    "AgentPublishIntervalMs": 5.0,
    "FrontendPublishIntervalMs": 18.0,
    "TimingPublishIntervalMs": 18.0
  },
  "Scheduling": {
    "Positioning": {
      "TimeToPixelScale": 2.0,
      "BaseYOffset": 0.0,
      "SiblingSpacing": 10.0,
      "ContainerTopPadding": 40.0,
      "ContainerBottomPadding": 10.0,
      "BaseHeight": 50.0,
      "RouterDropdownHeight": 26.0
    },
    "Defaults": {
      "DefaultTaskDuration": 200.0
    }
  }
}