	#region Test: Dependency Graph Integration

	[Fact]
	public async System.Threading.Tasks.Task StartLoadedProcedureAsync_ShouldPassCorrectDependencyGraphToTriggerService()
	{
		// Arrange
		var skillId = Guid.NewGuid();
		var node = CreateSkillNode(Guid.NewGuid(), skillId);
		var nodes = new List<Node> { node };
		var edges = new List<DependencyEdge>();

		var expectedDependencyGraph = new DependencyGraph
		{
			Prerequisites = new Dictionary<Guid, SkillEventPrerequisites>
			{
				[node.Id] = new SkillEventPrerequisites // Use node ID as key
				{
					SkillId = node.Id, // Use node ID
					StartPrerequisites = new List<EventPrerequisite>().AsReadOnly(),
					FinishPrerequisites = new List<EventPrerequisite>().AsReadOnly()
				}
			}
		};

		var initResult = new ExecutionInitializationResult
		{
			Success = true,
			Nodes = nodes,
			Edges = edges,
		};

		_executionInitializerMock.Setup(x => x.InitializeAsync(It.IsAny<DateTimeOffset>(), It.IsAny<CancellationToken>()))
			.ReturnsAsync(initResult);

		_dependencyGraphAnalyzerMock.Setup(x => x.AnalyzeDependencies(nodes, edges))
			.Returns(expectedDependencyGraph);

		_stateManagerMock.Setup(x => x.Initialize(It.IsAny<IReadOnlyList<Node>>(), It.IsAny<IReadOnlyDictionary<Guid, IRuntimeAgent>>()));
		_executionTriggerServiceMock.Setup(x => x.Stop());

		DependencyGraph? capturedGraph = null;
		_executionTriggerServiceMock.Setup(x => x.Start(It.IsAny<DependencyGraph>(), It.IsAny<IReadOnlyList<Node>>(), It.IsAny<VariableContext?>()))
			.Callback<DependencyGraph, IReadOnlyList<Node>, VariableContext?>((graph, _, __) => capturedGraph = graph);

		_progressMonitorMock.Setup(x => x.IsExecutionComplete()).Returns(true);
		_progressMonitorMock.Setup(x => x.IsExecutionSuccessful()).Returns(true);
		_progressMonitorMock.Setup(x => x.GetExecutionStatistics()).Returns(new Dictionary<string, int>
		{
			["Total"] = 1,
			["Pending"] = 0,
			["Running"] = 0,
			["Completed"] = 1,
			["Failed"] = 0
		});

		var orchestrator = CreateOrchestrator();

		// Act
		var cts = new CancellationTokenSource(TimeSpan.FromSeconds(2));
		var executionTask = orchestrator.StartLoadedProcedureAsync(cts.Token);

		await System.Threading.Tasks.Task.Delay(100);

		_eventBus.PublishEvent(new ExecutionEvent
		{
			SkillId = node.Id, // Use node ID, not domain skill ID
			EventType = ExecutionEventType.Finish,
			Timestamp = DateTimeOffset.UtcNow
		});

		await executionTask;

		// Assert
		Assert.NotNull(capturedGraph);
		Assert.Equal(expectedDependencyGraph, capturedGraph);
	}

	#endregion

	#region Test: Initialization Failure

	[Fact]
	public async System.Threading.Tasks.Task StartLoadedProcedureAsync_WhenInitializationFails_ShouldReturnFalse()
	{
		// Arrange
		var initResult = new ExecutionInitializationResult
		{
			Success = false,
			ErrorMessage = "Test initialization failure",
			Nodes = new List<Node>(),
			Edges = new List<DependencyEdge>(),
			Schedule = null,
		};

		_executionInitializerMock.Setup(x => x.InitializeAsync(It.IsAny<DateTimeOffset>(), It.IsAny<CancellationToken>()))
			.ReturnsAsync(initResult);

		var orchestrator = CreateOrchestrator();

		// Act
		var result = await orchestrator.StartLoadedProcedureAsync(CancellationToken.None);

		// Assert
		Assert.False(result);
		_dependencyGraphAnalyzerMock.Verify(x => x.AnalyzeDependencies(It.IsAny<IReadOnlyList<Node>>(), It.IsAny<IReadOnlyList<DependencyEdge>>()), Times.Never);
		_executionTriggerServiceMock.Verify(x => x.Start(It.IsAny<DependencyGraph>(), It.IsAny<IReadOnlyList<Node>>(), It.IsAny<VariableContext?>()), Times.Never);
	}

	#endregion

	#region Test: Complex Dependency Integration - B Start triggers A Start, A Finish cancels B

	/// <summary>
	/// Integration test for complex dependency scenario:
	/// - Skill A: Regular skill, 5 second duration
	/// - Skill B: Adaptive skill, 100 second nominal duration
	/// Dependencies:
	/// 1. B Start → A Start (A waits for B to start)
	/// 2. A Finish → B Finish (B is cancelled when A finishes)
	/// Expected behavior:
	/// 1. B starts immediately (no start prerequisites)
	/// 2. B publishes Start event
	/// 3. A starts (triggered by B.Start)
	/// 4. A executes for 5 seconds
	/// 5. A finishes and publishes Finish event
	/// 6. B is cancelled by A.Finish
	/// 7. B stops and publishes Finish event
	/// 8. Total duration: ~5 seconds (not 100 seconds)
	/// </summary>
	[Fact]
	public void BStartTriggersAStart_AFinishCancelsB_DependencyAnalysisTest()
	{
		// Arrange - Create test skills
		var skillA = CreateRegularSkill("SkillA", 5.0);
		var skillB = CreateAdaptiveSkill("SkillB", 100.0);

		// Create nodes
		var agentId = Guid.NewGuid();
		var nodeA = CreateSkillNode(skillA, agentId, 5.0);
		var nodeB = CreateSkillNode(skillB, agentId, 100.0);

		// Create edges: B (left) → A (left) and A (right) → B (right)
		var edges = new List<DependencyEdge>
		{
			new DependencyEdge
			{
				Id = Guid.NewGuid(),
				SourceId = nodeB.Id,
				TargetId = nodeA.Id,
				SourceHandle = "left",  // B Start
				TargetHandle = "left"    // → A Start
			},
			new DependencyEdge
			{
				Id = Guid.NewGuid(),
				SourceId = nodeA.Id,
				TargetId = nodeB.Id,
				SourceHandle = "right",  // A Finish
				TargetHandle = "right"   // → B Finish
			}
		};

		var nodes = new List<Node> { nodeA, nodeB };

		// Create real dependency graph analyzer and hierarchy processor
		var hierarchyProcessorMock = new Mock<INodeHierarchyProcessor>();
		hierarchyProcessorMock.Setup(p => p.ProcessHierarchy(It.IsAny<IReadOnlyList<Node>>()))
			.Returns((IReadOnlyList<Node> inputNodes) => new NodeHierarchyInfo
			{
				TaskNodes = Array.Empty<TaskNode>(),
				SkillExecutionNodes = inputNodes.OfType<SkillExecutionNode>().ToList(),
				ParentToChildrenMapping = new Dictionary<Guid, IReadOnlyList<Node>>(),
				TaskToSkillMapping = new Dictionary<Guid, IReadOnlyList<SkillExecutionNode>>(),
				SkillToTaskMapping = new Dictionary<Guid, TaskNode>()
			});

		var analyzer = new DependencyGraphAnalyzer(
			hierarchyProcessorMock.Object,
			Mock.Of<ILogger<DependencyGraphAnalyzer>>());

		// Act - Analyze dependencies
		var dependencyGraph = analyzer.AnalyzeDependencies(nodes, edges);

		// Assert - Verify dependency graph structure
		Assert.NotNull(dependencyGraph);
		Assert.Equal(2, dependencyGraph.Prerequisites.Count);

		// Verify Skill A prerequisites
		var skillAPrereqs = dependencyGraph.GetPrerequisites(nodeA.Id);
		Assert.NotNull(skillAPrereqs);
		Assert.Single(skillAPrereqs.StartPrerequisites); // A waits for B.Start
		Assert.Empty(skillAPrereqs.FinishPrerequisites); // A has no finish prerequisites
		Assert.Equal(nodeB.Id, skillAPrereqs.StartPrerequisites[0].DependencySkillId);
		Assert.Equal(EventTriggerType.Start, skillAPrereqs.StartPrerequisites[0].RequiredEventType);

		// Verify Skill B prerequisites
		var skillBPrereqs = dependencyGraph.GetPrerequisites(nodeB.Id);
		Assert.NotNull(skillBPrereqs);
		Assert.Empty(skillBPrereqs.StartPrerequisites); // B has no start prerequisites
		Assert.Single(skillBPrereqs.FinishPrerequisites); // B waits for A.Finish to finish
		Assert.Equal(nodeA.Id, skillBPrereqs.FinishPrerequisites[0].DependencySkillId);
		Assert.Equal(EventTriggerType.Finish, skillBPrereqs.FinishPrerequisites[0].RequiredEventType);

		// Verify B is an adaptive skill (has finish prerequisites)
		Assert.True(skillBPrereqs.IsAdaptive, "Skill B should be adaptive (has finish prerequisites)");
		Assert.False(skillAPrereqs.IsAdaptive, "Skill A should not be adaptive");

		// Verify immediate start skills
		var immediateStart = dependencyGraph.GetImmediateStartSkills().ToList();
		Assert.Single(immediateStart); // Only B can start immediately
		Assert.Equal(nodeB.Id, immediateStart[0]);

		// Verify adaptive skills
		var adaptiveSkills = dependencyGraph.GetAdaptiveSkills().ToList();
		Assert.Single(adaptiveSkills); // Only B is adaptive
		Assert.Equal(nodeB.Id, adaptiveSkills[0]);
	}

	private static Skill CreateRegularSkill(string name, double duration)
	{
		return new Skill
		{
			Id = Guid.NewGuid(),
			Name = name,
			Description = "Test regular skill",
			Properties = new List<Property>
			{
				new Property
				{
					Name = "NominalDuration",
					Value = TypedValue.Number(duration),
					Direction = PropertyDirection.Input
				}
			},
			AgentIds = new List<Guid>()
		};
	}

	private static Skill CreateAdaptiveSkill(string name, double duration)
	{
		return new Skill
		{
			Id = Guid.NewGuid(),
			Name = $"Adaptive_{name}",
			Description = "Test adaptive skill",
			Properties = new List<Property>
			{
				new Property
				{
					Name = "NominalDuration",
					Value = TypedValue.Number(duration),
					Direction = PropertyDirection.Input
				}
			},
			AgentIds = new List<Guid>()
		};
	}

	private static SkillExecutionNode CreateSkillNode(Skill skill, Guid agentId, double duration)
	{
		return new SkillExecutionNode
		{
			Id = Guid.NewGuid(),
			Position = new NodePosition { X = 0, Y = 0 },
			SkillExecutionTask = new SkillExecutionTask
			{
				Name = skill.Name,
				Skill = skill,
				AgentId = agentId,
				StartTime = 0,
				Duration = duration,
				ExecutionId = Guid.NewGuid()
			}
		};
	}

	#endregion
}
