    [Fact]
    public async System.Threading.Tasks.Task TriggerSchedulingWithDataAsync_WithFailingCallback_LogsErrorButContinues()
    {
        // Arrange
        var nodes = new List<Node> { CreateTaskNode("Task1") };
        var edges = new List<DependencyEdge>();
        var changeType = GraphChangeType.NodeUpdated;
        var entityId = Guid.NewGuid();

        Func<System.Threading.Tasks.Task> failingCallback = () => throw new InvalidOperationException("Callback error");

        SetupSuccessfulScheduling();

        // Act
        var result = await _service.TriggerSchedulingWithDataAsync(nodes, edges, changeType, entityId, failingCallback);

        // Allow time for background task to complete
        await System.Threading.Tasks.Task.Delay(500);

        // Assert
        Assert.True(result);
        VerifyLogCalled(LogLevel.Error, Times.AtLeastOnce());
    }

    [Fact]
    public async System.Threading.Tasks.Task TriggerSchedulingWithDataAsync_WithSchedulingFailure_LogsWarning()
    {
        // Arrange
        var nodes = new List<Node> { CreateTaskNode("Task1") };
        var edges = new List<DependencyEdge>();
        var changeType = GraphChangeType.EdgeAdded;
        var entityId = Guid.NewGuid();

        SetupFailedScheduling();

        // Act
        var result = await _service.TriggerSchedulingWithDataAsync(nodes.AsReadOnly(), edges.AsReadOnly(), changeType, entityId);

        // Allow time for background task to complete
        await System.Threading.Tasks.Task.Delay(500);

        // Assert
        Assert.True(result); // Method returns true even if scheduling fails
        VerifyLogCalled(LogLevel.Warning, Times.AtLeastOnce());
    }

    [Fact]
    public async System.Threading.Tasks.Task TriggerSchedulingWithDataAsync_WithNoUpdatedNodes_LogsInformation()
    {
        // Arrange
        var nodes = new List<Node> { CreateTaskNode("Task1") };
        var edges = new List<DependencyEdge>();
