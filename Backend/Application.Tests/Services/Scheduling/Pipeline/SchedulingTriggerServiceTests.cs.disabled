using FHOOE.Freydis.Application.Services.Scheduling.Pipeline;
using FHOOE.Freydis.Application.Services.Scheduling.Computation;
using FHOOE.Freydis.Application.Services.Scheduling.Models;
using FHOOE.Freydis.Domain;
using FHOOE.Freydis.Domain.Entities.Procedure;
using FHOOE.Freydis.Domain.Entities.Common;
using Microsoft.Extensions.Logging;
using Moq;

namespace FHOOE.Freydis.Application.Tests.Services.Scheduling.Pipeline;

/// <summary>
/// Comprehensive TDD unit tests for SchedulingTriggerService.
/// Tests background scheduling execution, repository interactions, error handling, and callbacks.
/// </summary>
public class SchedulingTriggerServiceTests
{
    private readonly Mock<ITimingCalculationOrchestrator> _mockTimingCalculationOrchestrator;
    private readonly Mock<IRepository<Node>> _mockNodeRepository;
    private readonly Mock<IRepository<DependencyEdge>> _mockEdgeRepository;
    private readonly Mock<ILogger<SchedulingTriggerService>> _mockLogger;
    private readonly SchedulingTriggerService _service;

    public SchedulingTriggerServiceTests()
    {
        _mockTimingCalculationOrchestrator = new Mock<ITimingCalculationOrchestrator>();
        _mockNodeRepository = new Mock<IRepository<Node>>();
        _mockEdgeRepository = new Mock<IRepository<DependencyEdge>>();
        _mockLogger = new Mock<ILogger<SchedulingTriggerService>>();
        
        _service = new SchedulingTriggerService(
            _mockTimingCalculationOrchestrator.Object,
            _mockNodeRepository.Object,
            _mockEdgeRepository.Object,
            _mockLogger.Object);
    }

    #region Constructor Tests

    [Fact]
    public void Constructor_WithNullTimingCalculationOrchestrator_ThrowsArgumentNullException()
    {
        // Act & Assert
        var exception = Assert.Throws<ArgumentNullException>(() => 
            new SchedulingTriggerService(null!, _mockNodeRepository.Object, _mockEdgeRepository.Object, _mockLogger.Object));
        Assert.Equal("timingCalculationOrchestrator", exception.ParamName);
    }

    [Fact]
    public void Constructor_WithNullNodeRepository_ThrowsArgumentNullException()
    {
        // Act & Assert
        var exception = Assert.Throws<ArgumentNullException>(() => 
            new SchedulingTriggerService(_mockTimingCalculationOrchestrator.Object, null!, _mockEdgeRepository.Object, _mockLogger.Object));
        Assert.Equal("nodeRepository", exception.ParamName);
    }

    [Fact]
    public void Constructor_WithNullEdgeRepository_ThrowsArgumentNullException()
    {
        // Act & Assert
        var exception = Assert.Throws<ArgumentNullException>(() => 
            new SchedulingTriggerService(_mockTimingCalculationOrchestrator.Object, _mockNodeRepository.Object, null!, _mockLogger.Object));
        Assert.Equal("edgeRepository", exception.ParamName);
    }

    [Fact]
    public void Constructor_WithNullLogger_ThrowsArgumentNullException()
    {
        // Act & Assert
        var exception = Assert.Throws<ArgumentNullException>(() => 
            new SchedulingTriggerService(_mockTimingCalculationOrchestrator.Object, _mockNodeRepository.Object, _mockEdgeRepository.Object, null!));
        Assert.Equal("logger", exception.ParamName);
    }

    [Fact]
    public void Constructor_WithValidParameters_CreatesInstance()
    {
        // Act
        var service = new SchedulingTriggerService(
            _mockTimingCalculationOrchestrator.Object,
            _mockNodeRepository.Object,
            _mockEdgeRepository.Object,
            _mockLogger.Object);

        // Assert
        Assert.NotNull(service);
    }

    #endregion

    #region TriggerSchedulingAsync Tests

    [Fact]
    public async System.Threading.Tasks.Task TriggerSchedulingAsync_WithValidParameters_LoadsDataAndTriggersScheduling()
    {
        // Arrange
        var changeType = GraphChangeType.NodeAdded;
        var entityId = Guid.NewGuid();
        var nodes = new List<Node> { CreateTaskNode("Task1") };
        var edges = new List<DependencyEdge>();

        _mockNodeRepository.Setup(r => r.GetAllAsync()).ReturnsAsync(nodes);
        _mockEdgeRepository.Setup(r => r.GetAllAsync()).ReturnsAsync(edges);
        SetupSuccessfulScheduling();

        // Act
        await _service.TriggerSchedulingAsync(changeType, entityId);

        // Assert
        _mockNodeRepository.Verify(r => r.GetAllAsync(), Times.Once);
        _mockEdgeRepository.Verify(r => r.GetAllAsync(), Times.Once);
        VerifyLogCalled(LogLevel.Debug, Times.AtLeastOnce());
    }

    [Fact]
    public async System.Threading.Tasks.Task TriggerSchedulingAsync_WithRepositoryException_CatchesAndLogsError()
    {
        // Arrange
        var changeType = GraphChangeType.NodeAdded;
        var entityId = Guid.NewGuid();
        var expectedException = new InvalidOperationException("Repository error");

        _mockNodeRepository.Setup(r => r.GetAllAsync()).ThrowsAsync(expectedException);

        // Act
        await _service.TriggerSchedulingAsync(changeType, entityId);

        // Assert
        VerifyLogCalled(LogLevel.Error, Times.Once());
    }

    [Fact]
    public async System.Threading.Tasks.Task TriggerSchedulingAsync_WithCallback_ExecutesCallback()
    {
        // Arrange
        var changeType = GraphChangeType.NodeAdded;
        var entityId = Guid.NewGuid();
        var callbackExecuted = false;
        var nodes = new List<Node> { CreateTaskNode("Task1") };
        var edges = new List<DependencyEdge>();

        Func<System.Threading.Tasks.Task> callback = async () => 
        {
            await System.Threading.Tasks.Task.Delay(10);
            callbackExecuted = true;
        };

        _mockNodeRepository.Setup(r => r.GetAllAsync()).ReturnsAsync(nodes);
        _mockEdgeRepository.Setup(r => r.GetAllAsync()).ReturnsAsync(edges);
        SetupSuccessfulScheduling();

        // Act
        await _service.TriggerSchedulingAsync(changeType, entityId, callback);

        // Allow time for background task to complete
        await System.Threading.Tasks.Task.Delay(500);

        // Assert
        Assert.True(callbackExecuted);
    }

    [Fact]
    public async System.Threading.Tasks.Task TriggerSchedulingAsync_WithCancellation_RespectsCancellationToken()
    {
        // Arrange
        var changeType = GraphChangeType.NodeAdded;
        var entityId = Guid.NewGuid();
        var nodes = new List<Node> { CreateTaskNode("Task1") };
        var edges = new List<DependencyEdge>();

        using var cts = new CancellationTokenSource();
        cts.Cancel(); // Cancel immediately

        _mockNodeRepository.Setup(r => r.GetAllAsync()).ReturnsAsync(nodes);
        _mockEdgeRepository.Setup(r => r.GetAllAsync()).ReturnsAsync(edges);

        // Act & Assert - Should not throw but should handle cancellation gracefully
        await _service.TriggerSchedulingAsync(changeType, entityId, cancellationToken: cts.Token);
    }

    #endregion

