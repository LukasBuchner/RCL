    #region Helper Methods

    private TaskNode CreateTaskNode(string name)
    {
        return new TaskNode
        {
            Id = Guid.NewGuid(),
            Position = new NodePosition { X = 0, Y = 0 },
            Task = new FHOOE.Freydis.Domain.Entities.Procedure.Task
            {
                Name = name,
                Description = $"Test task: {name}",
                StartTime = 0.0,
                Duration = 100.0,
                FinishTime = 100.0,
                IsExecuting = false,
                Progress = 0.0
            }
        };
    }

    private SkillExecutionNode CreateSkillExecutionNode(string name, Guid? parentId = null)
    {
        return new SkillExecutionNode
        {
            Id = Guid.NewGuid(),
            Position = new NodePosition { X = 0, Y = 0 },
            ParentId = parentId,
            SkillExecutionTask = new SkillExecutionTask
            {
                Name = name,
                StartTime = 0.0,
                Duration = 50.0,
                FinishTime = 50.0,
                IsExecuting = false,
                Progress = 0.0,
                Skill = new Skill
                {
                    Id = Guid.NewGuid(),
                    Name = name,
                    Description = $"Test skill: {name}",
                    Properties = new List<Property>(),
                    AgentIds = new List<Guid>()
                },
                AgentId = Guid.NewGuid()
            }
        };
    }

    private DependencyEdge CreateDependencyEdge(Guid sourceId, Guid targetId)
    {
        return new DependencyEdge
        {
            Id = Guid.NewGuid(),
            SourceId = sourceId,
            TargetId = targetId,
            SourceHandle = "bottom",
            TargetHandle = "top"
        };
    }

    private void SetupSuccessfulScheduling()
    {
        var successResult = new ScheduleResult
        {
            Success = true,
            UpdatedNodes = new List<Node> { CreateTaskNode("UpdatedTask") }.AsReadOnly(),
            NodeSchedules = new List<NodeSchedule>().AsReadOnly(),
            ErrorMessage = null
        };

        _mockTimingCalculationOrchestrator.Setup(p => p.CalculateAsync(It.IsAny<SchedulingRequest>(), It.IsAny<CancellationToken>()))
            .ReturnsAsync(successResult);
    }

    private void SetupFailedScheduling()
    {
        var failedResult = new ScheduleResult
        {
            Success = false,
            UpdatedNodes = null,
            NodeSchedules = new List<NodeSchedule>().AsReadOnly(),
            ErrorMessage = "Scheduling failed"
        };

        _mockTimingCalculationOrchestrator.Setup(p => p.CalculateAsync(It.IsAny<SchedulingRequest>(), It.IsAny<CancellationToken>()))
            .ReturnsAsync(failedResult);
    }

    private void SetupSchedulingWithNoUpdates()
    {
        var noUpdatesResult = new ScheduleResult
        {
            Success = true,
            UpdatedNodes = new List<Node>().AsReadOnly(), // Empty list
            NodeSchedules = new List<NodeSchedule>().AsReadOnly(),
            ErrorMessage = null
        };

        _mockTimingCalculationOrchestrator.Setup(p => p.CalculateAsync(It.IsAny<SchedulingRequest>(), It.IsAny<CancellationToken>()))
            .ReturnsAsync(noUpdatesResult);
    }

    private void SetupSuccessfulSchedulingWithTiming()
    {
        var nodeSchedules = new List<NodeSchedule>
        {
            new NodeSchedule
            {
                NodeId = Guid.NewGuid(),
                NodeType = NodeScheduleType.TaskNode,
                AbsoluteStartTime = 0.0,
                Duration = 100.0,
                AbsoluteFinishTime = 100.0
            }
        };

        var successResult = new ScheduleResult
        {
            Success = true,
            UpdatedNodes = new List<Node> { CreateTaskNode("UpdatedTask") }.AsReadOnly(),
            NodeSchedules = nodeSchedules.AsReadOnly(),
            ErrorMessage = null
        };

        _mockTimingCalculationOrchestrator.Setup(p => p.CalculateAsync(It.IsAny<SchedulingRequest>(), It.IsAny<CancellationToken>()))
            .ReturnsAsync(successResult);
    }

    private void VerifyLogCalled(LogLevel level, Times times)
    {
        _mockLogger.Verify(
            x => x.Log(
                level,
                It.IsAny<EventId>(),
                It.Is<It.IsAnyType>((v, t) => true),
                It.IsAny<Exception>(),
                It.IsAny<Func<It.IsAnyType, Exception?, string>>()),
            times);
    }

    #endregion
}